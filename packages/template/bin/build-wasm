#!/bin/bash

set -e

# Build custom Ruby WASM with all gems embedded (advanced/optional).
#
# DEFAULT APPROACH (recommended):
#   - Uses official @ruby/3.3-wasm-wasi package (ruby+stdlib.wasm)
#   - Gems distributed separately via gems.tar.gz (run: bin/pack-gems)
#   - Faster rebuilds when changing gems
#
# THIS SCRIPT (optional):
#   - Builds a custom ruby.wasm with gems embedded
#   - Takes 5-10 minutes to build
#   - Use when you need gems with native extensions
#
# Usage: ./bin/build-wasm

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="$(dirname "$SCRIPT_DIR")"
RUBY_WASM_DIR="$TEMPLATE_DIR/ruby-wasm"
PUBLIC_DIR="$TEMPLATE_DIR/src/templates/default/public"

echo "=== Building Custom Ruby WASM ==="
echo
echo "Note: This is optional. The default approach uses:"
echo "  - Official @ruby/3.3-wasm-wasi package"
echo "  - Gems via gems.tar.gz (run: bin/pack-gems)"
echo

# Check if ruby-wasm directory exists
if [ ! -d "$RUBY_WASM_DIR" ]; then
  echo "Error: ruby-wasm directory not found at $RUBY_WASM_DIR"
  exit 1
fi

# Ensure public directory exists
mkdir -p "$PUBLIC_DIR"

cd "$RUBY_WASM_DIR"

# Install bundler dependencies
echo "Installing dependencies..."
bundle install --quiet

# Build using wasmify-rails pack command
echo "Building Ruby WASM with embedded gems (this takes 5-10 minutes)..."
echo

if [ -f "bin/pack" ]; then
  ./bin/pack "$TEMPLATE_DIR/src/templates/default"
else
  # Fallback to bundle exec rbwasm
  echo "Warning: bin/pack not found, using rbwasm directly"
  bundle exec rbwasm build \
    --ruby-version 3.3 \
    --target wasm32-unknown-wasip1 \
    -o dist/ruby.wasm

  cp dist/ruby.wasm "$PUBLIC_DIR/"
fi

# Verify output
if [ -f "$PUBLIC_DIR/ruby.wasm" ]; then
  SIZE=$(du -h "$PUBLIC_DIR/ruby.wasm" | cut -f1)
  echo
  echo "=== Build Complete ==="
  echo "  Output: $PUBLIC_DIR/ruby.wasm"
  echo "  Size: $SIZE"
  echo
  echo "The custom WASM will be used instead of the official package."
else
  echo "Error: Build failed - ruby.wasm not created"
  exit 1
fi
