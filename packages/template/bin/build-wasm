#!/bin/bash

set -e

# Build Ruby WASM with cross-compiled gems (hybrid wasi-vfs approach).
#
# Flow:
#   1. npm install in ruby-wasm/ (gets official @ruby/3.3-wasm-wasi binary)
#   2. bundle install (host gems for cross-compilation tooling)
#   3. ruby bin/pack (cross-compile gems + wasi-vfs pack)
#   4. Copy dist/ruby.wasm → src/templates/default/public/ruby.wasm
#   5. Generate ruby.wasm.hash from Gemfile.lock SHA256
#
# Prerequisites:
#   - wasi-vfs CLI (cargo install wasi-vfs-cli)
#   - Ruby + Bundler
#   - Node.js + npm
#
# Usage: ./bin/build-wasm

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="$(dirname "$SCRIPT_DIR")"
RUBY_WASM_DIR="$TEMPLATE_DIR/ruby-wasm"
PUBLIC_DIR="$TEMPLATE_DIR/src/templates/default/public"

echo "=== Building Ruby WASM (hybrid wasi-vfs) ==="
echo

# --- Preflight checks --------------------------------------------------------

if [ ! -d "$RUBY_WASM_DIR" ]; then
  echo "Error: ruby-wasm directory not found at $RUBY_WASM_DIR"
  exit 1
fi

if ! command -v wasi-vfs &> /dev/null; then
  echo "Error: wasi-vfs CLI not found"
  echo "Install it with: cargo install wasi-vfs-cli"
  exit 1
fi

# --- Step 1: Install official WASM binary ------------------------------------

echo "Step 1/4: Installing official Ruby WASM binary..."
cd "$RUBY_WASM_DIR"
npm install --no-audit --no-fund
echo

# --- Step 2: Install host gems (for cross-compilation tooling) ---------------

echo "Step 2/4: Installing host gems..."
bundle install --quiet
echo

# --- Step 3: Cross-compile gems + wasi-vfs pack -----------------------------

echo "Step 3/4: Cross-compiling gems + packing with wasi-vfs..."
echo
bundle exec ruby bin/pack
echo

# --- Step 4: Copy output + generate hash ------------------------------------

echo "Step 4/4: Copying output..."
mkdir -p "$PUBLIC_DIR"

if [ ! -f "dist/ruby.wasm" ]; then
  echo "Error: Build failed — dist/ruby.wasm not created"
  exit 1
fi

cp dist/ruby.wasm "$PUBLIC_DIR/"
SIZE=$(du -h "$PUBLIC_DIR/ruby.wasm" | cut -f1)

# Generate hash from Gemfile.lock for cache versioning
GEMFILE_HASH=$(sha256sum Gemfile.lock | cut -c1-16)
echo "$GEMFILE_HASH" > "$PUBLIC_DIR/ruby.wasm.hash"

echo
echo "=== Build Complete ==="
echo "  Output: $PUBLIC_DIR/ruby.wasm"
echo "  Size:   $SIZE"
echo "  Hash:   $GEMFILE_HASH"
